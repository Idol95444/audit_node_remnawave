# remnawave-node-audit — пример конфига.
#
# Реальный конфиг должен лежать по пути /etc/remnawave-audit/audit.conf,
# mode 600, owner root. НИКОГДА не коммитить с реальными значениями.
#
# Файл создаётся install.sh под umask 077 (защита от race chmod).

# --- Telegram ---
BOT_TOKEN=
ADMIN_CHAT_ID=                # CSV: можно несколько ID (личка + канал, формат -100... для каналов)

# --- Идентификация ноды ---
NODE_NAME=                    # человекочитаемое имя (заголовок алерта)
TZ=Europe/Moscow              # для дневной сводки в 08:00 локального времени

# --- Порты (источник правды для UFW + аудита) ---
NODE_PORT=2222                # связь с панелью; читается также из docker-compose.yml
INBOUND_PORTS=443,8388        # порты Xray-инбаундов (открыты для клиентов)
EXTRA_PORTS_WHITELIST=        # доп. порты, не относящиеся к ноде, но ожидаемые открытыми

# --- Безопасность ---
SSH_ADMIN_IPS=                # CSV админских IP — попытки логина с этих IP не считать за brute

# --- Опц. auto-recovery ---
AUTO_RECOVER=0                # 1 = пытаться docker compose up -d при CRIT container_status (max 3/час)

# --- Пороги ---
THRESHOLD_CPU=80
THRESHOLD_RAM=85
THRESHOLD_DISK=85

# --- Cooldown'ы (секунды) ---
COOLDOWN_CRITICAL_SEC=900     # 15 мин
COOLDOWN_WARNING_SEC=3600     # 1 час

# --- Опц. внешний пробинг ---
EXTERNAL_PROBE_URL=           # https://<panel>/api/health, опционально
